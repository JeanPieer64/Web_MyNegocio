<%- include('partials/header') %>

<center>
    <h1><font color="#cc0000">Catálogo de Categorías</font></h1>
    <p><font size="4"></font></p>
    
    <br>

    <table border="1" cellpadding="10" cellspacing="0" width="80%" bgcolor="#ffffff">
        <tr bgcolor="#333333">
            <th><font color="white">ID Categoría</font></th>
            <th><font color="white">Nombre de Categoría</font></th>
            <th><font color="white">Descripción</font></th>
        </tr>
        
        <% categorias.forEach(function(cat) { %>
            <tr>
                <td align="center"><b><%= cat.IdCategoria %></b></td>
                <td><%= cat.NombreCategoria %></td>
                <td><%= cat.Descripcion %></td>
            </tr>
        <% }); %>

    </table>

    <br><br>
    
    <a href="/reportes"><b><font color="#0000cc" size="4">⬅ Volver al menú de Reportes</font></b></a>

</center>

<%- include('partials/footer') %>