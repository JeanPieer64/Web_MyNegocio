<%- include('partials/header') %>

<center>
    <br>
    <h1><font color="#1A365D">Editar Empleado</font></h1>
    <br>

    <form action="/empleados/actualizar" method="POST">
        <input type="hidden" name="idEmpleado" value="<%= empleado.IdEmpleado %>">
        
        <table border="1" cellpadding="10" cellspacing="0" width="40%" bgcolor="#f4f7f6">
            <tr>
                <td><b>Nombres:</b></td>
                <td><input type="text" name="nombre" value="<%= empleado.Nombre %>" required style="width: 100%; padding: 5px;"></td>
            </tr>
            <tr>
                <td><b>Apellidos:</b></td>
                <td><input type="text" name="apellidos" value="<%= empleado.Apellidos %>" required style="width: 100%; padding: 5px;"></td>
            </tr>
            <tr>
                <td colspan="2" align="center">
                    <button type="submit" style="padding: 10px 20px; background-color: orange; color: white; border: none; cursor: pointer;">🔄 Actualizar Datos</button>
                    <a href="/empleados" style="margin-left: 10px; color: red;">Cancelar</a>
                </td>
            </tr>
        </table>
    </form>
</center>

<%- include('partials/footer') %>