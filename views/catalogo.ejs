<%- include('partials/header') %>

<style>
    @media print {
        @page {
            margin-top: 0;
            margin-bottom: 0;
        }
        body * {
            visibility: hidden;
        }
        #zonaImprimible, #zonaImprimible * {
            visibility: visible;
        }
        #zonaImprimible {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
        }
        .no-imprimir {
            display: none !important;
        }
    }
</style>

<div id="zonaImprimible">
    <center>
        <h1><font color="#cc0000">Catálogo Filtrado por Categoría</font></h1>
        <br>

        <form action="/reportes/catalogo" method="POST" class="no-imprimir">
            <table border="0" cellpadding="10" bgcolor="#f4f7f6">
                <tr>
                    <td><b>Seleccione una Categoría:</b></td>
                    <td>
                        <select name="idCategoria" required>
                            <option value="">-- Elija una opción --</option>
                            <% categorias.forEach(function(cat) { %>
                                <option value="<%= cat.IdCategoria %>"><%= cat.NombreCategoria %></option>
                            <% }); %>
                        </select>
                    </td>
                    <td>
                        <input type="submit" value="Buscar Productos">
                    </td>
                </tr>
            </table>
        </form>

        <br><br>

        <% if (productos && productos.length > 0) { %>
            
            <button class="no-imprimir" onclick="window.print()" style="padding: 10px 20px; margin-bottom: 20px; background-color: #cc0000; color: white; border: none; font-weight: bold; cursor: pointer;">
                Descargar PDF
            </button>

            <table border="1" cellpadding="10" cellspacing="0" width="70%" bgcolor="#ffffff">
                <tr bgcolor="#1A365D"> 
                    <th><font color="white">ID</font></th>
                    <th><font color="white">Nombre del Producto</font></th>
                    <th><font color="white">Precio</font></th>
                    <th><font color="white">Stock</font></th>
                </tr>
                
                <% productos.forEach(function(prod) { %>
                    <tr>
                        <td align="center"><b><%= prod.IdProducto %></b></td>
                        <td><%= prod.NombreProducto %></td>
                        <td align="center">S/ <%= parseFloat(prod.PrecioUnidad).toFixed(2) %></td>
                        <td align="center"><%= prod.UnidadesEnExistencia %></td>
                    </tr>
                <% }); %>
            </table>
        <% } else if (productos && productos.length === 0) { %>
            <p class="no-imprimir"><font color="red" size="4"><b>No se encontraron productos en esta categoría.</b></font></p>
        <% } %>

    </center>
</div>

<br><br>

<%- include('partials/footer') %>